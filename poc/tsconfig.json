{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    // Vite bundles the .tsx sources directly; tsc is type-check only. Without
    // this it emitted .js next to every .tsx in src/, which Vite could then
    // resolve ahead of the .tsx (stale-build footgun).
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "view-transition-router": ["../src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
